# ─── ML pipeline ───────────────────────────────────────────────────────────
# Raw + processed datasets and on-the-fly INT8 calibration trees are huge
# and reproducible from data_fetcher.py + data_prep.py.
ml_pipeline/data/

# Training runs: keep the canonical reference run's best.pt / last.pt and
# its CSV/PNG plots so a fresh clone has a verifiable artefact. Exclude
# per-epoch checkpoints (epochN.pt, ~10 MB each), intermediate export
# formats (best.onnx, best_saved_model/ — both can be regenerated by
# export.py from best.pt), and any throwaway smoke / scratch runs.
ml_pipeline/runs/**/weights/epoch*.pt
ml_pipeline/runs/**/weights/best.onnx
ml_pipeline/runs/**/weights/best_saved_model/
ml_pipeline/runs/**/weights/last_saved_model/
ml_pipeline/runs/*-smoke*/
ml_pipeline/runs/*-scratch*/
ml_pipeline/runs/*-debug*/

# Ultralytics writes these to the working directory during TFLite export
# and never cleans them up. They're all regeneratable.
yolov8n.pt
yolov8n.onnx
yolov8n-cls.pt
yolov8n_saved_model/
calibration_image_sample_data_*.npy

